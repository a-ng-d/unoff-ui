{
  "bar": {
    "minHeight": {
      "$type": "dimension",
      "$value": "{size.pos.large}"
    },
    "gap": {
      "$type": "dimension",
      "$value": "{size.pos.xxsmall}"
    },
    "padding": {
      "default": {
        "top": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "right": {
          "$type": "dimension",
          "$value": "{size.pos.xsmall}"
        },
        "bottom": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "left": {
          "$type": "dimension",
          "$value": "{size.pos.xsmall}"
        }
      },
      "mobile": {
        "top": {
          "$type": "dimension",
          "$value": "{size.pos.xxxsmall}"
        },
        "right": {
          "$type": "dimension",
          "$value": "{size.pos.xsmall}"
        },
        "bottom": {
          "$type": "dimension",
          "$value": "{size.pos.xxxsmall}"
        },
        "left": {
          "$type": "dimension",
          "$value": "{size.pos.xsmall}"
        }
      }
    },
    "background": {
      "color": {
        "$type": "color",
        "$value": "{grey.transparent}"
      }
    },
    "border": {
      "width": {
        "$type": "dimension",
        "$value": "{size.pos.unit}"
      },
      "color": {
        "$type": "color",
        "$value": "{figma.color.border.default}"
      }
    },
    "height": {
      "compact": {
        "$type": "dimension",
        "$value": "{size.pos.medium}"
      }
    }
  }
}
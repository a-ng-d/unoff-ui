{
  "draggableWindow": {
    "width": {
      "$type": "dimension",
      "$value": "296px"
    },
    "radius": {
      "$type": "dimension",
      "$value": "{border.radius.xxlarge}"
    },
    "shadow": {
      "$type": "shadow",
      "$value": "{elevation.500ModalWindow}"
    },
    "background": {
      "color": {
        "$type": "color",
        "$value": "{figma.color.bg.default}"
      }
    },
    "border": {
      "color": {
        "$type": "color",
        "$value": "{grey.transparent}"
      },
      "width": {
        "$type": "dimension",
        "$value": "{size.null}"
      },
      "offset": {
        "$type": "dimension",
        "$value": "{size.null}"
      }
    },
    "header": {
      "border": {
        "width": {
          "$type": "dimension",
          "$value": "{size.pos.unit}"
        },
        "color": {
          "$type": "color",
          "$value": "{figma.color.border.default}"
        }
      }
    },
    "content": {
      "padding": {
        "top": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        },
        "right": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        },
        "bottom": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        },
        "left": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        }
      },
      "gap": {
        "$type": "dimension",
        "$value": "{size.pos.xxxsmall}"
      }
    }
  }
}
{
  "chip": {
    "gap": {
      "$type": "dimension",
      "$value": "{size.pos.xxxsmall}"
    },
    "padding": {
      "top": {
        "$type": "dimension",
        "$value": "{size.null}"
      },
      "right": {
        "$type": "dimension",
        "$value": "{size.pos.xxxsmall}"
      },
      "bottom": {
        "$type": "dimension",
        "$value": "{size.null}"
      },
      "left": {
        "$type": "dimension",
        "$value": "{size.pos.xxxsmall}"
      }
    },
    "height": {
      "$type": "dimension",
      "$value": "{size.pos.xsmall}"
    },
    "margin": {
      "top": {
        "$type": "dimension",
        "$value": "{size.null}"
      },
      "right": {
        "$type": "dimension",
        "$value": "{size.null}"
      },
      "bottom": {
        "$type": "dimension",
        "$value": "{size.null}"
      },
      "left": {
        "$type": "dimension",
        "$value": "{size.pos.xxsmall}"
      }
    },
    "radius": {
      "$type": "dimension",
      "$value": "{border.radius.small}"
    },
    "text": {
      "color": {
        "default": {
          "$type": "color",
          "$value": "{figma.color.text.brand.default}"
        },
        "inactive": {
          "$type": "color",
          "$value": "{figma.color.text.default}"
        },
        "hover": {
          "$type": "color",
          "$value": "{figma.color.text.brand.default}"
        },
        "onBackground": {
          "$type": "color",
          "$value": "{grey.1000}"
        }
      },
      "weight": {
        "default": {
          "$type": "fontWeights",
          "$value": "{font.weight.accent}"
        },
        "onBackground": {
          "$type": "fontWeights",
          "$value": "{font.weight.normal}"
        }
      },
      "size": {
        "$type": "dimension",
        "$value": "{font.size.xxsmall}"
      },
      "letterSpacing": {
        "$type": "dimension",
        "$value": "{font.letterSpacing.pos.xlarge}"
      },
      "transform": {
        "$type": "string",
        "$value": "none"
      }
    },
    "background": {
      "color": {
        "default": {
          "$type": "color",
          "$value": "{figma.color.bg.selected.secondary}"
        },
        "inactive": {
          "$type": "color",
          "$value": "{figma.color.bg.tertiary}"
        },
        "hover": {
          "$type": "color",
          "$value": "{figma.color.bg.selected.default}"
        },
        "onBackground": {
          "$type": "color",
          "$value": "rgba(255, 255, 255, 0.4)"
        }
      }
    },
    "border": {
      "color": {
        "default": {
          "$type": "color",
          "$value": "{grey.transparent}"
        },
        "inactive": {
          "$type": "color",
          "$value": "{grey.transparent}"
        },
        "hover": {
          "$type": "color",
          "$value": "{grey.transparent}"
        },
        "onBackground": {
          "$type": "color",
          "$value": "{grey.transparent}"
        }
      },
      "width": {
        "default": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "inactive": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "hover": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "onBackground": {
          "$type": "dimension",
          "$value": "{size.null}"
        }
      },
      "offset": {
        "default": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "inactive": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "hover": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "onBackground": {
          "$type": "dimension",
          "$value": "{size.null}"
        }
      }
    }
  }
}
{
  "multipleSlider": {
    "margin": {
      "top": {
        "$type": "dimension",
        "$value": "{size.pos.large}"
      },
      "right": {
        "$type": "dimension",
        "$value": "{size.null}"
      },
      "bottom": {
        "$type": "dimension",
        "$value": "{size.pos.xxsmall}"
      },
      "left": {
        "$type": "dimension",
        "$value": "{size.null}"
      }
    },
    "padding": {
      "top": {
        "$type": "dimension",
        "$value": "{size.null}"
      },
      "right": {
        "$type": "dimension",
        "$value": "{size.pos.medium}"
      },
      "bottom": {
        "$type": "dimension",
        "$value": "{size.null}"
      },
      "left": {
        "$type": "dimension",
        "$value": "{size.pos.medium}"
      }
    },
    "height": {
      "$type": "dimension",
      "$value": "{size.pos.xsmall}"
    },
    "radius": {
      "$type": "dimension",
      "$value": "{border.radius.small}"
    },
    "background": {
      "color": {
        "$type": "color",
        "$value": "{figma.color.bg.secondary}"
      }
    },
    "border": {
      "color": {
        "$type": "color",
        "$value": "{figma.color.border.disabled.strong}"
      },
      "width": {
        "$type": "dimension",
        "$value": "{size.pos.unit}"
      }
    },
    "progress": {
      "color": {
        "$type": "color",
        "$value": "{figma.color.bg.brand.default}"
      }
    },
    "status": {
      "gap": {
        "$type": "dimension",
        "$value": "{size.pos.xxsmall}"
      },
      "margin": {
        "top": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "right": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "bottom": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "left": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        }
      },
      "height": {
        "$type": "dimension",
        "$value": "{size.pos.xsmall}"
      }
    }
  }
}
{
  "membersList": {
    "gap": {
      "$type": "dimension",
      "$value": "{size.neg.xxxsmall}"
    },
    "avatar": {
      "radius": {
        "$type": "dimension",
        "$value": "{border.radius.xlarge}"
      },
      "width": {
        "$type": "dimension",
        "$value": "{size.pos.medium}"
      },
      "height": {
        "$type": "dimension",
        "$value": "{size.pos.medium}"
      },
      "border": {
        "width": {
          "$type": "dimension",
          "$value": "{size.pos.xunit}"
        },
        "offset": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "color": {
          "$type": "color",
          "$value": "{framer.color.bg.default}"
        }
      }
    },
    "more": {
      "padding": {
        "top": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "right": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        },
        "bottom": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "left": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        }
      }
    },
    "text": {
      "color": {
        "$type": "color",
        "$value": "{framer.color.text.default}"
      }
    }
  }
}
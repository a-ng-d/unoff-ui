{
  "accordion": {
    "padding": {
      "top": {
        "$type": "dimension",
        "$value": "{size.pos.xxxsmall}"
      },
      "right": {
        "$type": "dimension",
        "$value": "{size.null}"
      },
      "bottom": {
        "$type": "dimension",
        "$value": "{size.pos.xxxsmall}"
      },
      "left": {
        "$type": "dimension",
        "$value": "{size.null}"
      }
    },
    "border": {
      "width": {
        "$type": "dimension",
        "$value": "{size.pos.unit}"
      },
      "color": {
        "$type": "color",
        "$value": "{framer.color.divider}"
      }
    },
    "row": {
      "gap": {
        "$type": "dimension",
        "$value": "{size.null}"
      },

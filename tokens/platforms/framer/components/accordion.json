        "$value": "{size.pos.xlarge}"
      },
      "padding": {
        "top": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "right": {
          "$type": "dimension",
          "$value": "{size.pos.xsmall}"
        },
        "bottom": {
          "$type": "dimension",
          "$value": "{size.null}"

      }
    },
    "text": {
      "color": {
        "default": {
          "$type": "color",
          "$value": "{framer.color.text.default}"
        },
        "hover": {
          "$type": "color",
          "$value": "{framer.color.text.default}"
        },
        "expanded": {
          "$type": "color",
          "$value": "{framer.color.text.default}"
        },
        "disabled": {
          "$type": "color",
          "$value": "{framer.color.text.tertiary}"
        }
      }
    },
    "icon": {
      "color": {
        "default": {
          "$type": "color",
          "$value": "{framer.color.text.default}"
        },
        "hover": {
          "$type": "color",
          "$value": "{framer.color.text.default}"
        },
        "expanded": {
          "$type": "color",
          "$value": "{framer.color.text.default}"
        },
        "disabled": {
          "$type": "color",
          "$value": "{framer.color.text.tertiary}"
        }

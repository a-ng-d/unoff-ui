{
  "colorChip": {
    "radius": {
      "$type": "dimension",
      "$value": "{border.radius.small}"
    },
    "border": {
      "color": {
        "$type": "color",
        "$value": "rgba(0, 0, 0, 0.1)"
      },
      "width": {
        "$type": "dimension",
        "$value": "{size.pos.unit}"
      },
      "offset": {
        "$type": "dimension",
        "$value": "{size.neg.unit}"
      }
    }
  }
}
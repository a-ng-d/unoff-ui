{
  "card": {
    "gap": {
      "$type": "dimension",
      "$value": "{size.pos.xxsmall}"
    },
    "radius": {
      "$type": "dimension",
      "$value": "{border.radius.xlarge}"
    },
    "padding": {
      "top": {
        "$type": "dimension",
        "$value": "{size.pos.xxsmall}"
      },
      "right": {
        "$type": "dimension",
        "$value": "{size.pos.xxsmall}"
      },
      "bottom": {
        "$type": "dimension",
        "$value": "{size.pos.xxsmall}"
      },
      "left": {
        "$type": "dimension",
        "$value": "{size.pos.xxsmall}"
      }
    },
    "width": {
      "$type": "dimension",
      "$value": "200px"
    },
    "ratio": {
      "$type": "string",
      "$value": "2 / 1"
    },
    "background": {
      "color": {
        "default": {
          "$type": "color",
          "$value": "{framer.color.bg.default}"
        },
        "hover": {
          "$type": "color",
          "$value": "{framer.color.bg.secondary}"
        },
        "focus": {
          "$type": "color",
          "$value": "{framer.color.tint.dimmed}"
        }
      }
    },
    "border": {
      "color": {
        "default": {
          "$type": "color",
          "$value": "{grey.transparent}"
        },
        "hover": {
          "$type": "color",
          "$value": "{grey.transparent}"
        },
        "focus": {
          "$type": "color",
          "$value": "{framer.color.tint.default}"
        }
      },
      "width": {
        "default": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "hover": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "focus": {
          "$type": "dimension",
          "$value": "{size.pos.unit}"
        }
      },
      "offset": {
        "default": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "hover": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "focus": {
          "$type": "dimension",
          "$value": "{size.neg.unit}"
        }
      }
    },
    "actions": {
      "gap": {
        "$type": "dimension",
        "$value": "{size.pos.xxsmall}"
      },
      "padding": {
        "top": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        },
        "right": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        },
        "bottom": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        },
        "left": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        }
      }
    },
    "content": {
      "gap": {
        "$type": "dimension",
        "$value": "{size.pos.xxxsmall}"
      }
    }
  }
}
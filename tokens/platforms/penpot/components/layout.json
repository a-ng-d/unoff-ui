          "$type": "dimension",
          "$value": "{size.null}"
        }
      }
    },
    "centered": {
      "padding": {
        "top": {
          "$type": "dimension",
          "$value": "{size.pos.small}"
        },
        "right": {
          "$type": "dimension",
          "$value": "{size.pos.small}"
        },
        "bottom": {
          "$type": "dimension",
          "$value": "{size.pos.small}"
        },

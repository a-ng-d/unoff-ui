{
  "sectionTitle": {
    "height": {
      "$type": "dimension",
      "$value": "{size.pos.medium}"
    },
    "gap": {
      "$type": "dimension",
      "$value": "{size.pos.xxxsmall}"
    },
    "padding": {
      "top": {
        "$type": "dimension",
        "$value": "{size.null}"
      },
      "right": {
        "$type": "dimension",
        "$value": "{size.pos.xxxsmall}"
      },
      "bottom": {
        "$type": "dimension",
        "$value": "{size.null}"
      },
      "left": {
        "$type": "dimension",
        "$value": "{size.pos.xxsmall}"
      }
    },
    "text": {
      "font": {
        "family": {
          "$type": "fontFamilies",
          "$value": "{text.fontFamily}"
        },
        "size": {
          "$type": "dimension",
          "$value": "{font.size.small}"
        },
        "weight": {
          "$type": "fontWeights",
          "$value": "{font.weight.medium}"
        }
      },
      "letterSpacing": {
        "$type": "dimension",
        "$value": "{font.letterSpacing.pos.medium}"
      },
      "lineHeight": {
        "$type": "number",
        "$value": "{font.lineHeight.default}"
      },
      "color": {
        "$type": "color",
        "$value": "{penpot.color.foreground.primary}"
      },
      "transform": {
        "$type": "string",
        "$value": "uppercase"
      }
    },
    "info": {
      "icon": {
        "width": {
          "$type": "dimension",
          "$value": "{size.pos.medium}"
        },
        "height": {
          "$type": "dimension",
          "$value": "{size.pos.medium}"
        }
      }
    }
  }
}
{
  "dropzone": {
    "padding": {
      "top": {
        "$type": "dimension",
        "$value": "{size.pos.small}"
      },
      "right": {
        "$type": "dimension",
        "$value": "{size.pos.small}"
      },
      "bottom": {
        "$type": "dimension",
        "$value": "{size.pos.small}"
      },
      "left": {
        "$type": "dimension",
        "$value": "{size.pos.small}"
      }
    },
    "gap": {
      "$type": "dimension",
      "$value": "{size.pos.xxsmall}"
    },
    "minWidth": {
      "$type": "dimension",
      "$value": "200px"
    },
    "minHeight": {
      "$type": "dimension",
      "$value": "200px"
    },
    "border": {
      "color": {
        "default": {
          "$type": "color",
          "$value": "{penpot.color.background.quaternary}"
        },
        "hover": {
          "$type": "color",
          "$value": "{penpot.color.accent.primary.default}"
        },
        "disabled": {
          "$type": "color",
          "$value": "{penpot.color.background.tertiary}"
        }
      },
      "width": {
        "default": {
          "$type": "dimension",
          "$value": "{size.pos.unit}"
        },
        "hover": {
          "$type": "dimension",
          "$value": "{size.pos.xunit}"
        },
        "disabled": {
          "$type": "dimension",
          "$value": "{size.pos.unit}"
        }
      },
      "offset": {
        "default": {
          "$type": "dimension",
          "$value": "{size.neg.unit}"
        },
        "hover": {
          "$type": "dimension",
          "$value": "{size.neg.xunit}"
        },
        "disabled": {
          "$type": "dimension",
          "$value": "{size.neg.unit}"
        }
      },
      "style": {
        "default": {
          "$type": "string",
          "$value": "dashed"
        },
        "hover": {
          "$type": "string",
          "$value": "solid"
        },
        "disabled": {
          "$type": "string",
          "$value": "dashed"
        }
      }
    },
    "background": {
      "color": {
        "default": {
          "$type": "color",
          "$value": "{penpot.color.background.primary}"
        },
        "hover": {
          "$type": "color",
          "$value": "{penpot.color.accent.primary.muted}"
        },
        "disabled": {
          "$type": "color",
          "$value": "{penpot.color.background.secondary}"
        }
      }
    },
    "radius": {
      "$type": "dimension",
      "$value": "{border.radius.medium}"
    }
  }
}
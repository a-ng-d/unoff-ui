{
  "draggableWindow": {
    "width": {
      "$type": "dimension",
      "$value": "320px"
    },
    "radius": {
      "$type": "dimension",
      "$value": "{border.radius.xxlarge}"
    },
    "shadow": {
      "$type": "string",
      "$value": "none"
    },
    "background": {
      "color": {
        "$type": "color",
        "$value": "{penpot.color.background.primary}"
      }
    },
    "border": {
      "color": {
        "$type": "color",
        "$value": "{penpot.color.background.quaternary}"
      },
      "width": {
        "$type": "dimension",
        "$value": "{size.pos.unit}"
      },
      "offset": {
        "$type": "dimension",
        "$value": "{size.neg.unit}"
      }
    },
    "header": {
      "border": {
        "width": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "color": {
          "$type": "color",
          "$value": "{grey.transparent}"
        }
      }
    },
    "content": {
      "padding": {
        "top": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        },
        "right": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        },
        "bottom": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        },
        "left": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        }
      },
      "gap": {
        "$type": "dimension",
        "$value": "{size.pos.xxxsmall}"
      }
    }
  }
}
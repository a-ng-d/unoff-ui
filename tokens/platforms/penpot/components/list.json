{
  "list": {
    "background": {
      "color": {
        "default": {
          "$type": "color",
          "$value": "{penpot.color.background.primary}"
        },
        "alternate": {
          "$type": "color",
          "$value": "{penpot.color.background.tertiary}"
        }
      }
    },
    "padding": {
      "top": {
        "$type": "dimension",
        "$value": "{size.pos.unit}"
      },
      "right": {
        "$type": "dimension",
        "$value": "{size.null}"
      },
      "bottom": {
        "$type": "dimension",
        "$value": "{size.pos.unit}"
      },
      "left": {
        "$type": "dimension",
        "$value": "{size.null}"
      }
    },
    "border": {
      "width": {
        "$type": "dimension",
        "$value": "{size.pos.unit}"
      },
      "color": {
        "$type": "color",
        "$value": "{penpot.color.background.quaternary}"
      }
    },
    "message": {
      "padding": {
        "top": {
          "$type": "dimension",
          "$value": "{size.pos.xsmall}"
        },
        "right": {
          "$type": "dimension",
          "$value": "{size.pos.xsmall}"
        },
        "bottom": {
          "$type": "dimension",
          "$value": "{size.pos.xsmall}"
        },
        "left": {
          "$type": "dimension",
          "$value": "{size.pos.xsmall}"
        }
      }
    }
  }
}
{
  "dropdown": {
    "height": {
      "$type": "dimension",
      "$value": "{size.pos.medium}"
    },
    "padding": {
      "top": {
        "$type": "dimension",
        "$value": "{size.null}"
      },
      "right": {
        "$type": "dimension",
        "$value": "{size.pos.xxsmall}"
      },
      "bottom": {
        "$type": "dimension",
        "$value": "{size.null}"
      },
      "left": {
        "$type": "dimension",
        "$value": "{size.pos.xxsmall}"
      }
    },
    "radius": {
      "$type": "dimension",
      "$value": "{border.radius.xlarge}"
    },
    "gap": {
      "$type": "dimension",
      "$value": "{size.pos.xxxsmall}"
    },
    "background": {
      "color": {
        "default": {
          "$type": "color",
          "$value": "{penpot.color.background.tertiary}"
        },
        "hover": {
          "$type": "color",
          "$value": "{penpot.color.background.quaternary}"
        },
        "focus": {
          "$type": "color",
          "$value": "{penpot.color.background.tertiary}"
        },
        "disabled": {
          "$type": "color",
          "$value": "{penpot.color.background.primary}"
        },
        "onSelected": {
          "$type": "color",
          "$value": "{penpot.color.background.quaternary}"
        }
      }
    },
    "border": {
      "color": {
        "default": {
          "$type": "color",
          "$value": "{grey.transparent}"
        },
        "hover": {
          "$type": "color",
          "$value": "{grey.transparent}"
        },
        "focus": {
          "$type": "color",
          "$value": "{penpot.color.accent.primary.default}"
        },
        "disabled": {
          "$type": "color",
          "$value": "{penpot.color.background.quaternary}"
        },
        "onSelected": {
          "$type": "color",
          "$value": "{penpot.color.accent.primary.default}"
        }
      },
      "width": {
        "default": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "hover": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "focus": {
          "$type": "dimension",
          "$value": "{size.pos.unit}"
        },
        "disabled": {
          "$type": "dimension",
          "$value": "{size.pos.unit}"
        }
      },
      "offset": {
        "default": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "hover": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "focus": {
          "$type": "dimension",
          "$value": "{size.pos.unit}"
        },
        "disabled": {
          "$type": "dimension",
          "$value": "{size.pos.unit}"
        }
      }
    },
    "text": {
      "color": {
        "default": {
          "$type": "color",
          "$value": "{penpot.color.foreground.primary}"
        },
        "hover": {
          "$type": "color",
          "$value": "{penpot.color.foreground.primary}"
        },
        "focus": {
          "$type": "color",
          "$value": "{penpot.color.foreground.primary}"
        },
        "disabled": {
          "$type": "color",
          "$value": "{penpot.color.foreground.secondary}"
        }
      }
    },
    "caret": {
      "width": {
        "$type": "dimension",
        "$value": "{size.pos.xsmall}"
      },
      "height": {
        "$type": "dimension",
        "$value": "{size.pos.xsmall}"
      },
      "color": {
        "default": {
          "$type": "color",
          "$value": "{penpot.color.icon.default}"
        },
        "hover": {
          "$type": "color",
          "$value": "{penpot.color.icon.default}"
        },
        "focus": {
          "$type": "color",
          "$value": "{penpot.color.icon.default}"
        },
        "disabled": {
          "$type": "color",
          "$value": "{penpot.color.icon.default}"
        }
      }
    },
    "status": {
      "gap": {
        "$type": "dimension",
        "$value": "{size.pos.xxsmall}"
      },
      "height": {
        "$type": "dimension",
        "$value": "{size.pos.medium}"
      },
      "margin": {
        "top": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "right": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "bottom": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "left": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        }
      }
    }

{
  "text": {
    "fontFamily": {
      "$type": "fontFamilies",
      "$value": "Work Sans"
    },
    "color": {
      "primary": {
        "$type": "color",
        "$value": "{penpot.color.foreground.primary}"
      },
      "secondary": {
        "$type": "color",
        "$value": "{penpot.color.foreground.secondary}"
      },
      "tertiary": {
        "$type": "color",
        "$value": "{penpot.color.foreground.disabled}"
      },
      "success": {
        "$type": "color",
        "$value": "{penpot.color.accent.success}"
      },
      "warning": {
        "$type": "color",
        "$value": "{penpot.color.accent.warning}"
      },
      "alert": {
        "$type": "color",
        "$value": "{penpot.color.accent.error}"
      },
      "inverse": {
        "$type": "color",
        "$value": "{penpot.color.background.primary}"
      }
    },
    "fontWeight": {
      "medium": {
        "$type": "fontWeights",
        "$value": "{font.weight.medium}"
      },
      "bold": {
        "$type": "fontWeights",
        "$value": "{font.weight.bold}"
      }
    },
    "styles": {
      "default": {
        "fontFamily": {
          "$type": "fontFamilies",
          "$value": "{text.fontFamily}"
        },
        "fontSize": {
          "$type": "dimension",
          "$value": "{font.size.small}"
        },
        "fontWeight": {
          "$type": "fontWeights",
          "$value": "{font.weight.medium}"
        },
        "lineHeight": {
          "$type": "number",
          "$value": "{font.lineHeight.default}"
        },
        "letterSpacing": {
          "$type": "dimension",
          "$value": "{font.letterSpacing.pos.large}"
        }
      },
      "small": {
        "fontFamily": {
          "$type": "fontFamilies",
          "$value": "{text.fontFamily}"
        },
        "fontSize": {
          "$type": "dimension",
          "$value": "{font.size.xsmall}"
        },
        "fontWeight": {
          "$type": "fontWeights",
          "$value": "{font.weight.medium}"
        },
        "lineHeight": {
          "$type": "number",
          "$value": "{font.lineHeight.default}"
        },
        "letterSpacing": {
          "$type": "dimension",
          "$value": "{font.letterSpacing.pos.xlarge}"
        }
      },
      "large": {
        "fontFamily": {
          "$type": "fontFamilies",
          "$value": "{text.fontFamily}"
        },
        "fontSize": {
          "$type": "dimension",
          "$value": "{font.size.medium}"
        },
        "fontWeight": {
          "$type": "fontWeights",
          "$value": "{font.weight.medium}"
        },
        "lineHeight": {
          "$type": "number",
          "$value": "{font.lineHeight.large}"
        },
        "letterSpacing": {
          "$type": "dimension",
          "$value": "{font.letterSpacing.pos.medium}"
        }
      },
      "xlarge": {
        "fontFamily": {
          "$type": "fontFamilies",
          "$value": "{text.fontFamily}"
        },
        "fontSize": {
          "$type": "dimension",
          "$value": "{font.size.large}"
        },
        "fontWeight": {
          "$type": "fontWeights",
          "$value": "{font.weight.medium}"
        },
        "lineHeight": {
          "$type": "number",
          "$value": "{font.lineHeight.large}"
        },
        "letterSpacing": {
          "$type": "dimension",
          "$value": "{font.letterSpacing.pos.small}"
        }
      },
      "link": {
        "color": {
          "$type": "color",
          "$value": "{penpot.color.accent.primary.default}"
        },
        "decoration": {
          "$type": "string",
          "$value": "none"
        },
        "borderFocus": {
          "$type": "string",
          "$value": "none"
        },
        "decorationFocus": {
          "$type": "string",
          "$value": "underline"
        }
      },
      "label": {
        "color": {
          "$type": "color",
          "$value": "{penpot.color.foreground.secondary}"
        },
        "height": {
          "$type": "dimension",
          "$value": "{size.pos.medium}"
        },
        "padding": {
          "top": {
            "$type": "dimension",
            "$value": "{size.null}"
          },
          "right": {
            "$type": "dimension",
            "$value": "{size.pos.xxxsmall}"
          },
          "bottom": {
            "$type": "dimension",
            "$value": "{size.null}"
          },
          "left": {
            "$type": "dimension",
            "$value": "{size.pos.xxsmall}"
          }
        },
        "gap": {
          "$type": "dimension",
          "$value": "{size.pos.xxxsmall}"
        }
      }
    },
    "default": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{text.styles.default.fontFamily}",
        "fontSize": "{text.styles.default.fontSize}",
        "fontWeight": "{text.styles.default.fontWeight}",
        "lineHeight": "{text.styles.default.lineHeight}",
        "letterSpacing": "{text.styles.default.letterSpacing}"
      }
    },
    "small": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{text.styles.small.fontFamily}",
        "fontSize": "{text.styles.small.fontSize}",
        "fontWeight": "{text.styles.small.fontWeight}",
        "lineHeight": "{text.styles.small.lineHeight}",
        "letterSpacing": "{text.styles.small.letterSpacing}"
      }
    },
    "large": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{text.styles.large.fontFamily}",
        "fontSize": "{text.styles.large.fontSize}",
        "fontWeight": "{text.styles.large.fontWeight}",
        "lineHeight": "{text.styles.large.lineHeight}",
        "letterSpacing": "{text.styles.large.letterSpacing}"
      }
    },
    "xlarge": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{text.styles.xlarge.fontFamily}",
        "fontSize": "{text.styles.xlarge.fontSize}",
        "fontWeight": "{text.styles.xlarge.fontWeight}",
        "lineHeight": "{text.styles.xlarge.lineHeight}",
        "letterSpacing": "{text.styles.xlarge.letterSpacing}"
      }
    },
    "link": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{text.styles.default.fontFamily}",
        "fontSize": "{text.styles.default.fontSize}",
        "fontWeight": "{text.styles.default.fontWeight}",
        "lineHeight": "{text.styles.default.lineHeight}",
        "letterSpacing": "{text.styles.default.letterSpacing}",
        "textDecoration": "underline"
      }
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{text.styles.default.fontFamily}",
        "fontSize": "{text.styles.default.fontSize}",
        "fontWeight": "{text.styles.default.fontWeight}",
        "lineHeight": "{text.styles.default.lineHeight}",
        "letterSpacing": "{text.styles.default.letterSpacing}"
      }
    }
  }
}
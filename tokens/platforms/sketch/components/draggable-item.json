{
  "draggableItem": {
    "template": {
      "rows": {
        "$type": "dimension",
        "$value": "{size.pos.medium}"
      },
      "columns": {
        "$type": "string",
        "$value": "repeat(76, 1fr)"
      }
    },
    "padding": {
      "top": {
        "$type": "dimension",
        "$value": "{size.pos.xunit}"
      },
      "right": {
        "$type": "dimension",
        "$value": "{size.pos.xsmall}"
      },
      "bottom": {
        "$type": "dimension",
        "$value": "{size.pos.xunit}"
      },
      "left": {
        "$type": "dimension",
        "$value": "{size.pos.xsmall}"
      }
    },
    "background": {
      "color": {
        "default": {
          "$type": "color",
          "$value": "{sketch.color.background.primary}"
        },
        "selected": {
          "$type": "color",
          "$value": "{sketch.color.accent.disabled}"
        },
        "pressed": {
          "$type": "color",
          "$value": "{sketch.color.accent.disabled}"
        }
      }
    },
    "gap": {
      "$type": "dimension",
      "$value": "{size.pos.xxsmall}"
    },
    "ghost": {
      "color": {
        "$type": "color",
        "$value": "{sketch.color.accent.primary}"
      },
      "height": {
        "$type": "dimension",
        "$value": "{size.pos.xunit}"
      },
      "inset": {
        "$type": "dimension",
        "$value": "{size.neg.unit}"
      }
    },
    "param": {
      "width": {
        "compact": {
          "$type": "dimension",
          "$value": "112px"
        },
        "square": {
          "$type": "dimension",
          "$value": "{size.pos.medium}"
        }
      }
    }
  }
}
{
  "simpleItem": {
    "gap": {
      "$type": "dimension",
      "$value": "{size.pos.xxsmall}"
    },
    "padding": {
      "top": {
        "$type": "dimension",
        "$value": "{size.pos.xunit}"
      },
      "right": {
        "$type": "dimension",
        "$value": "{size.pos.xsmall}"
      },
      "bottom": {
        "$type": "dimension",
        "$value": "{size.pos.xunit}"
      },
      "left": {
        "$type": "dimension",
        "$value": "{size.pos.xsmall}"
      }
    },
    "minHeight": {
      "$type": "dimension",
      "$value": "{size.pos.medium}"
    },
    "background": {
      "color": {
        "default": {
          "$type": "color",
          "$value": "{sketch.color.background.primary}"
        },
        "hover": {
          "$type": "color",
          "$value": "{sketch.color.background.secondary}"
        },
        "focus": {
          "$type": "color",
          "$value": "{sketch.color.accent.disabled}"
        }
      }
    },
    "border": {
      "radius": {
        "$type": "dimension",
        "$value": "{border.radius.small}"
      },
      "width": {
        "default": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "focus": {
          "$type": "dimension",
          "$value": "{size.pos.unit}"
        }
      },
      "offset": {
        "default": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "focus": {
          "$type": "dimension",
          "$value": "{size.neg.unit}"
        }
      },
      "color": {
        "default": {
          "$type": "color",
          "$value": "{grey.transparent}"
        },
        "focus": {
          "$type": "color",
          "$value": "{sketch.color.accent.primary}"
        }
      }
    },
    "compact": {
      "minWidth": {
        "$type": "dimension",
        "$value": "112px"
      },
      "width": {
        "$type": "dimension",
        "$value": "112px"
      }
    },
    "square": {
      "minWidth": {
        "$type": "dimension",
        "$value": "{size.pos.medium}"
      },
      "width": {
        "$type": "dimension",
        "$value": "{size.pos.medium}"
      }
    }
  }
}
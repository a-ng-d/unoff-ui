{
  "dropdown": {
    "height": {
      "$type": "dimension",
      "$value": "{size.pos.medium}"
    },
    "padding": {
      "top": {
        "$type": "dimension",
        "$value": "{size.pos.xxsmall}"
      },
      "right": {
        "$type": "dimension",
        "$value": "{size.pos.xxsmall}"
      },
      "bottom": {
        "$type": "dimension",
        "$value": "{size.pos.xxsmall}"
      },
      "left": {
        "$type": "dimension",
        "$value": "{size.pos.xxsmall}"
      }
    },
    "radius": {
      "$type": "dimension",
      "$value": "{border.radius.large}"
    },
    "gap": {
      "$type": "dimension",
      "$value": "{size.pos.xxxsmall}"
    },
    "background": {
      "color": {
        "default": {
          "$type": "color",
          "$value": "{sketch.color.background.tertiary}"
        },
        "hover": {
          "$type": "color",
          "$value": "{sketch.color.background.secondary}"
        },
        "focus": {
          "$type": "color",
          "$value": "{sketch.color.background.tertiary}"
        },
        "disabled": {
          "$type": "color",
          "$value": "{sketch.color.background.secondary}"
        },
        "onSelected": {
          "$type": "color",
          "$value": "{sketch.color.accent.tertiary}"
        }
      }
    },
    "border": {
      "color": {
        "default": {
          "$type": "color",
          "$value": "{grey.transparent}"
        },
        "hover": {
          "$type": "color",
          "$value": "{grey.transparent}"
        },
        "focus": {
          "$type": "color",
          "$value": "{sketch.color.accent.primary}"
        },
        "disabled": {
          "$type": "color",
          "$value": "{grey.transparent}"
        },
        "onSelected": {
          "$type": "color",
          "$value": "{sketch.color.accent.primary}"
        }
      },
      "width": {
        "default": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "hover": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "focus": {
          "$type": "dimension",
          "$value": "{size.pos.unit}"
        },
        "disabled": {
          "$type": "dimension",
          "$value": "{size.null}"
        }
      },
      "offset": {
        "default": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "hover": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "focus": {
          "$type": "dimension",
          "$value": "{size.neg.unit}"
        },
        "disabled": {
          "$type": "dimension",
          "$value": "{size.null}"
        }
      }
    },
    "text": {
      "color": {
        "default": {
          "$type": "color",
          "$value": "{sketch.color.foreground.primary}"
        },
        "hover": {
          "$type": "color",
          "$value": "{sketch.color.foreground.primary}"
        },
        "focus": {
          "$type": "color",
          "$value": "{sketch.color.foreground.primary}"
        },
        "disabled": {
          "$type": "color",
          "$value": "{sketch.color.foreground.disabled}"
        }
      }
    },
    "caret": {
      "width": {
        "$type": "dimension",
        "$value": "{size.pos.xsmall}"
      },
      "height": {
        "$type": "dimension",
        "$value": "{size.pos.xsmall}"
      },
      "color": {
        "default": {
          "$type": "color",
          "$value": "{sketch.color.foreground.tertiary}"
        },
        "hover": {
          "$type": "color",
          "$value": "{sketch.color.foreground.tertiary}"
        },
        "focus": {
          "$type": "color",
          "$value": "{sketch.color.foreground.tertiary}"
        },
        "disabled": {
          "$type": "color",
          "$value": "{sketch.color.foreground.disabled}"
        }
      }
    },
    "status": {
      "gap": {
        "$type": "dimension",
        "$value": "{size.pos.xxsmall}"
      },
      "height": {
        "$type": "dimension",
        "$value": "{size.pos.medium}"
      },
      "margin": {
        "top": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "right": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "bottom": {
          "$type": "dimension",
          "$value": "{size.null}"
        },
        "left": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        }
      }
    }
  }
}
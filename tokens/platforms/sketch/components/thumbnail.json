{
  "thumbnail": {
    "width": {
      "$type": "dimension",
      "$value": "{size.pos.medium}"
    },
    "height": {
      "$type": "dimension",
      "$value": "{size.pos.medium}"
    },
    "padding": {
      "$type": "dimension",
      "$value": "{size.pos.xsmall}"
    },
    "radius": {
      "$type": "dimension",
      "$value": "{border.radius.large}"
    },
    "border": {
      "width": {
        "$type": "dimension",
        "$value": "{size.pos.unit}"
      },
      "offset": {
        "$type": "dimension",
        "$value": "{size.neg.unit}"
      },
      "color": {
        "$type": "color",
        "$value": "{sketch.color.border.primary}"
      }
    },
    "background": {
      "color": {
        "$type": "color",
        "$value": "{sketch.color.background.secondary}"
      }
    }
  }
}
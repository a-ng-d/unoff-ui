{
  "draggableWindow": {
    "width": {
      "$type": "dimension",
      "$value": "320px"
    },
    "radius": {
      "$type": "dimension",
      "$value": "{border.radius.xxxlarge}"
    },
    "shadow": {
      "$type": "shadow",
      "$value": "{elevation.500ModalWindow}"
    },
    "background": {
      "color": {
        "$type": "color",
        "$value": "{sketch.color.background.primary}"
      }
    },
    "border": {
      "color": {
        "$type": "color",
        "$value": "{sketch.color.border.primary}"
      },
      "width": {
        "$type": "dimension",
        "$value": "{size.pos.unit}"
      },
      "offset": {
        "$type": "dimension",
        "$value": "{size.neg.unit}"
      }
    },
    "header": {
      "border": {
        "width": {
          "$type": "dimension",
          "$value": "{size.pos.unit}"
        },
        "color": {
          "$type": "color",
          "$value": "{sketch.color.border.disabled}"
        }
      }
    },
    "content": {
      "padding": {
        "top": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        },
        "right": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        },
        "bottom": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        },
        "left": {
          "$type": "dimension",
          "$value": "{size.pos.xxsmall}"
        }
      },
      "gap": {
        "$type": "dimension",
        "$value": "{size.pos.xxxsmall}"
      }
    }
  }
}
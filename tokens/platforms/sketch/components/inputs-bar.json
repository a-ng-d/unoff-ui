{
  "inputsBar": {
    "gap": {
      "default": {
        "$type": "dimension",
        "$value": "{size.pos.xxsmall}"
      },
      "inner": {
        "$type": "dimension",
        "$value": "{size.pos.xunit}"
      }
    },
    "width": {
      "$type": "dimension",
      "$value": "{size.pos.xlarge}"
    },
    "padding": {
      "top": {
        "$type": "dimension",
        "$value": "{size.null}"
      },
      "right": {
        "$type": "dimension",
        "$value": "{size.pos.unit}"
      },
      "bottom": {
        "$type": "dimension",
        "$value": "{size.null}"
      },
      "left": {
        "$type": "dimension",
        "$value": "{size.pos.unit}"
      }
    },
    "margin": {
      "top": {
        "$type": "dimension",
        "$value": "{size.null}"
      },
      "right": {
        "$type": "dimension",
        "$value": "{size.neg.unit}"
      },
      "bottom": {
        "$type": "dimension",
        "$value": "{size.null}"
      },
      "left": {
        "$type": "dimension",
        "$value": "{size.neg.unit}"
      }
    },
    "radius": {
      "$type": "dimension",
      "$value": "{border.radius.large}"
    },
    "border": {
      "color": {
        "$type": "color",
        "$value": "{sketch.color.accent.primary}"
      },
      "width": {
        "$type": "dimension",
        "$value": "{size.pos.unit}"
      }
    },
    "input": {
      "radius": {
        "$type": "dimension",
        "$value": "{border.radius.null}"
      }
